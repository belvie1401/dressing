generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  STYLIST
  ADMIN
}

enum Category {
  TOP
  BOTTOM
  DRESS
  JACKET
  SHOES
  ACCESSORY
}

enum Season {
  SUMMER
  WINTER
  ALL
}

enum Occasion {
  CASUAL
  WORK
  EVENING
  SPORT
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  ENDED
}

enum LookbookStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

enum MessageType {
  TEXT
  IMAGE
  LOOKBOOK
  OUTFIT
  ZOOM_LINK
}

enum Plan {
  FREE
  CLIENT_PRO
  STYLIST_PRO
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REFUNDED
  WITHDRAWN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  avatar_url    String?
  role          Role     @default(CLIENT)
  active_role         String   @default("CLIENT")
  is_dual_role        Boolean  @default(false)
  referral_code       String?  @unique
  referred_by         String?
  referral_count      Int      @default(0)
  free_months_earned  Int      @default(0)
  style_profile Json?
  location      String?
  created_at    DateTime @default(now())

  clothing_items      ClothingItem[]
  outfits             Outfit[]
  calendar            CalendarEntry[]
  subscription        Subscription?
  sent_messages       Message[]       @relation("SentMessages")
  received_messages   Message[]       @relation("ReceivedMessages")
  stylist_connections StylistClient[] @relation("StylistConnections")
  client_connections  StylistClient[] @relation("ClientConnections")
  stylist_lookbooks   Lookbook[]      @relation("StylistLookbooks")
  client_lookbooks    Lookbook[]      @relation("ClientLookbooks")
  wallet              StylistWallet?
  stylist_transactions Transaction[]  @relation("StylistTransactions")
  client_transactions  Transaction[]  @relation("ClientTransactions")
}

model ClothingItem {
  id             String    @id @default(cuid())
  user_id        String
  user           User      @relation(fields: [user_id], references: [id])
  name           String?
  photo_url      String
  photo_hash     String?
  bg_removed_url String?
  category       Category
  colors         String[]
  material       String?
  season         Season    @default(ALL)
  occasion       Occasion  @default(CASUAL)
  brand          String?
  purchase_price Float?
  purchase_date  DateTime?
  wear_count     Int       @default(0)
  last_worn_at   DateTime?
  ai_tags        Json?
  created_at     DateTime  @default(now())

  outfit_items OutfitItem[]

  @@index([user_id, photo_hash])
}

model Outfit {
  id           String    @id @default(cuid())
  user_id      String
  user         User      @relation(fields: [user_id], references: [id])
  name         String
  occasion     Occasion?
  season       Season?
  ai_generated Boolean   @default(false)
  worn_count   Int       @default(0)
  last_worn_at DateTime?
  try_on_url   String?
  created_at   DateTime  @default(now())

  items          OutfitItem[]
  calendar       CalendarEntry[]
  lookbook_items LookbookOutfit[]
}

model OutfitItem {
  outfit_id String
  item_id   String
  outfit    Outfit       @relation(fields: [outfit_id], references: [id])
  item      ClothingItem @relation(fields: [item_id], references: [id])

  @@id([outfit_id, item_id])
}

model CalendarEntry {
  id           String    @id @default(cuid())
  user_id      String
  user         User      @relation(fields: [user_id], references: [id])
  outfit_id    String?
  outfit       Outfit?   @relation(fields: [outfit_id], references: [id])
  date         DateTime
  weather_data Json?
  notes        String?
  // Stylist appointment fields
  client_id    String?
  event_type   String?
  duration_min Int?
  zoom_link    String?
  title        String?
}

model StylistClient {
  id          String           @id @default(cuid())
  stylist_id  String
  client_id   String
  stylist     User             @relation("StylistConnections", fields: [stylist_id], references: [id])
  client      User             @relation("ClientConnections", fields: [client_id], references: [id])
  status      ConnectionStatus @default(PENDING)
  permissions Json?
  started_at  DateTime?
  created_at  DateTime         @default(now())
}

model Lookbook {
  id          String         @id @default(cuid())
  stylist_id  String
  client_id   String?
  stylist     User           @relation("StylistLookbooks", fields: [stylist_id], references: [id])
  client      User?          @relation("ClientLookbooks", fields: [client_id], references: [id])
  title       String
  description String?
  status      LookbookStatus @default(DRAFT)
  feedback    String?
  created_at  DateTime       @default(now())

  // Portfolio fields
  type          String?
  price         Int?
  photos        String[] @default([])
  before_photos String[] @default([])
  after_photos  String[] @default([])
  tags          String[] @default([])
  is_public     Boolean  @default(false)
  favorite_count Int     @default(0)

  outfits LookbookOutfit[]
}

model LookbookOutfit {
  lookbook_id String
  outfit_id   String
  lookbook    Lookbook @relation(fields: [lookbook_id], references: [id])
  outfit      Outfit   @relation(fields: [outfit_id], references: [id])

  @@id([lookbook_id, outfit_id])
}

model Message {
  id         String      @id @default(cuid())
  from_id    String
  to_id      String
  from       User        @relation("SentMessages", fields: [from_id], references: [id])
  to         User        @relation("ReceivedMessages", fields: [to_id], references: [id])
  content    String
  type       MessageType @default(TEXT)
  metadata   Json?
  read_at    DateTime?
  created_at DateTime    @default(now())
}

model Subscription {
  id                     String    @id @default(cuid())
  user_id                String    @unique
  user                   User      @relation(fields: [user_id], references: [id])
  plan                   Plan      @default(FREE)
  stripe_subscription_id String?
  status                 String
  current_period_end     DateTime?
}

model MagicLinkToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([email])
  @@index([token])
}

model StylistWallet {
  id                String   @id @default(cuid())
  stylist_id        String   @unique
  stylist           User     @relation(fields: [stylist_id], references: [id])
  balance           Float    @default(0)
  pending_balance   Float    @default(0)
  total_earned      Float    @default(0)
  stripe_account_id String?
  updated_at        DateTime @default(now()) @updatedAt
}

model Transaction {
  id                        String            @id @default(cuid())
  stylist_id                String
  stylist                   User              @relation("StylistTransactions", fields: [stylist_id], references: [id])
  client_id                 String?
  client                    User?             @relation("ClientTransactions", fields: [client_id], references: [id])
  session_id                String?
  gross_amount              Float
  platform_fee              Float
  net_amount                Float
  status                    TransactionStatus @default(PENDING)
  stripe_payment_intent_id  String?
  description               String?
  created_at                DateTime          @default(now())
  completed_at              DateTime?

  @@index([stylist_id])
  @@index([status])
}
